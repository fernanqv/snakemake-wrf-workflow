&time_control
 start_year                      	= {{start_year}}, {{start_year}}, {{start_year}},
 start_month                     	= 11, 11, 11,
 start_day                       	= 4, 4, 4, 
 start_hour                      	= 18, 18, 18, 
 start_minute                    	= 0, 0, 0, 
 start_second                    	= 0, 0, 0, 
 end_year                        	= {{end_year}}, {{end_year}}, {{end_year}},
 end_month                       	= 11, 11 ,11, 
 end_day                         	= 6, 6, 6, 
 end_hour                        	= 6, 6, 6, 
 end_minute                      	= 0, 0, 0, 
 end_second                      	= 0, 0, 0, 
